# ── Supabase (필수) ────────────────────────────────────────────────
# Supabase 프로젝트 Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role (또는 secret) 키 — 서버 전용. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── 세션 쿠키 서명 (필수) ──────────────────────────────────────────
# 임의의 긴 랜덤 문자열. 예: `openssl rand -base64 48` 또는 `node -e "console.log(crypto.randomBytes(48).toString('base64'))"`
SESSION_SECRET=change-me-to-a-long-random-string

# ── LibreTranslate 내용 번역 (선택) ────────────────────────────────
# 미설정 시 번역 없이 원문만 저장/표시됩니다.
# 자체 호스팅(Docker: LT_LOAD_ONLY=en,ko,ja) 또는 호스티드 인스턴스 URL
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
